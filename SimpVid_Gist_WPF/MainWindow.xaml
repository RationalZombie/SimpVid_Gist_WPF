<Window x:Class="SimpVid_Gist_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpVid_Gist_WPF"
        mc:Ignorable="d" FontFamily="Segoe UI Variable" WindowStyle="None"
        Title="SimpVid Gist"
        Height="680" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <DockPanel MouseDown="DockPanel_MouseDown" Background="Transparent" Grid.Row="0">
            <TextBlock Margin="16,0,0,0" FontSize="24" TextWrapping="Wrap" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center">SimpVid Gist</TextBlock>
            <Button Margin="0,0,10,0" Name="Button_Close" Content="Close" DockPanel.Dock="Right" HorizontalAlignment="Right" Height="30" Click="Button_Close_Click" Cursor="Hand" Background="#FE6584">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Width="50"
                                CornerRadius="15"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF4C70"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="DarkRed"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button Background="LightSeaGreen"
                Margin="0,0,10,0" Name="Button_Save" Content="Save" DockPanel.Dock="Right" HorizontalAlignment="Right" Height="30" Click="Button_Save_Click" Cursor="Arrow">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Width="50"
                                CornerRadius="15"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="SeaGreen"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="DarkOliveGreen"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

            </Button>

        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <StackPanel Margin="16">
                <TextBlock Margin="0,0,0,20" TextWrapping="Wrap">
                    Extract and summarize YouTube video transcripts. 
                    Provide an API key to also generate a summary. 
                    The default language is English.
                </TextBlock>

                <TextBlock Margin="0,0,0,10" TextWrapping="Wrap" FontWeight="SemiBold">Video URL or ID</TextBlock>
                <TextBox Name="UrlTextBox"/>

                <TextBlock Margin="0,10,0,5" TextWrapping="Wrap" FontWeight="SemiBold">AI Base URL (API Endpoint)</TextBlock>
                <TextBox Name="BaseUrlTextBox"/>

                <TextBlock Margin="0,10,0,5" TextWrapping="Wrap" FontWeight="SemiBold">Model Name</TextBlock>
                <TextBox Name="ModelTextBox"/>

                <TextBlock Margin="0,10,0,5" TextWrapping="Wrap" FontWeight="SemiBold">AI API key</TextBlock>
                <PasswordBox Name="ApiKeyTextBox" Height="25" PasswordChar="*"/>

                <Button x:Name="SaveButton" Margin="0,20,0,0" HorizontalAlignment="Center" Click="SaveButton_Click">Save AI Base URL and Model Name</Button>
                
                <Button Background="SkyBlue" x:Name="ExtractButton" Margin="0,10,0,10" Click="ExtractButton_Click" HorizontalAlignment="Center">
                    Extract Transcript
                </Button>

                <Button Background="Violet" x:Name="SummarizeButton" Margin="0,0,0,20" Click="SummarizeButton_Click" IsEnabled="False" HorizontalAlignment="Center">
                    Summarize Transcript

                </Button>

                <TextBlock Margin="0,0,0,10" TextWrapping="Wrap" FontWeight="Bold">Transcript</TextBlock>
                <TextBox x:Name="TranscriptTextBox" MinHeight="100" IsReadOnly="True" AcceptsReturn="True"/>

                <TextBlock Margin="0,10,0,10" TextWrapping="Wrap" FontWeight="Bold">Summary</TextBlock>
                <TextBox x:Name="SummaryTextBox" MinHeight="100" IsReadOnly="True" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
    
</Window>